generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id        String   @id @default(uuid())
  name      String
  location  String?
  createdAt DateTime @default(now())
  reviews   Review[]

  @@map("hotels")
}

model Review {
  id           String   @id @default(uuid())
  hotelId      String
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestName    String
  rating       Int
  source       String
  comment      String?
  sentimentTag String?
  department   String?  // e.g., 'Housekeeping', 'Front Desk'
  createdAt    DateTime @default(now())

  @@map("reviews")
}

model UserProfile {
  id      String  @id
  role    String  @default("manager")
  hotelId String?

  @@map("user_profiles")
}

model HotelCompetitor {
  id           String   @id @default(uuid())
  name         String
  cleanliness  Float
  value        Float
  service      Float
  location     Float
  reviewCount  Int
  avgPrice     Float
  sentiment    Float
  createdAt    DateTime @default(now())
}

model AISettings {
  id                  String   @id @default("default")
  persona            String   @default("Professional")
  autoPilotThreshold Float    @default(4.5)
  keywords           String[] @default([])
  geminiKey          String?
  updatedAt          DateTime @updatedAt
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       String   @default("dept_user") // 'admin' or 'dept_user'
  department String?  // e.g., 'Housekeeping', 'Front Desk'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}
